NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/gtvet-wel
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=
TRUST_PROXY=loopback
WEB_CONCURRENCY=1

# Optional email/invite delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional WhatsApp notifications
WHATSAPP_DEFAULT_COUNTRY_CODE=+233
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Optional GTVET-IDMS integration
IDMS_API_BASE=https://gtvet-idms-api-8466d2bbdaf1.herokuapp.com
IDMS_API_TOKEN=
IDMS_ALLOWED_PATH_PREFIXES=/
IDMS_REQUEST_TIMEOUT_MS=15000
