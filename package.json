{
  "name": "gtvet-wel-dashboard",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "build": "npm run build --prefix client",
    "heroku-postbuild": "npm ci --omit=dev --prefix server && npm ci --include=dev --prefix client && npm run build --prefix client",
    "heroku-cleanup": "npm prune --omit=dev --prefix server && rm -rf client/node_modules",
    "start": "npm start --prefix server"
  }
}
